# ── shared inference settings ─────────────────────────────────────────────────
# Number of CPU threads (set to your vCPU count; 1 for single-vCPU hosts)
N_THREADS=1
# Tokens processed per batch — lower = less RAM pressure
N_BATCH=128
# Lock model weights in RAM to avoid swap thrashing
USE_MLOCK=true
# Set to true to unload the previous domain model before loading a new one.
# Saves RAM (~300-600 MB) at the cost of a cold-start delay on domain switches.
EXCLUSIVE_LOADING=false

# ── files domain (Qwen2.5-Coder-0.5B Q4_K_M) ─────────────────────────────────
FILES_MODEL_PATH=./models/qwen2.5-coder-0.5b-instruct-q4_k_m.gguf
FILES_N_CTX=1024
FILES_MAX_TOKENS=128
FILES_TEMPERATURE=0.2
FILES_TOP_P=0.95

# ── git domain (Phi-2 Q4_K_M) ────────────────────────────────────────────────
GIT_MODEL_PATH=./models/phi-2-q4_k_m.gguf
GIT_N_CTX=1024
GIT_MAX_TOKENS=128
GIT_TEMPERATURE=0.2
GIT_TOP_P=0.95

# ── github domain (Phi-2 Q4_K_M — shares binary with git by default) ─────────
GITHUB_MODEL_PATH=./models/phi-2-q4_k_m.gguf
GITHUB_N_CTX=1024
GITHUB_MAX_TOKENS=128
GITHUB_TEMPERATURE=0.3
GITHUB_TOP_P=0.95

# ── rust domain (DeepSeek-Coder-1.3B Q4_K_M) ─────────────────────────────────
RUST_MODEL_PATH=./models/deepseek-coder-1.3b-instruct-q4_k_m.gguf
RUST_N_CTX=2048
RUST_MAX_TOKENS=256
RUST_TEMPERATURE=0.1
RUST_TOP_P=0.90

# ── ChatGPT / OpenAI API ──────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
# New accounts receive free credits; gpt-4o-mini is the cheapest model.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=512
OPENAI_TEMPERATURE=0.7

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Free tier: 15 RPM / 1M TPM / 1500 RPD with gemini-1.5-flash
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=512
GEMINI_TEMPERATURE=0.7

# ── Groq Cloud API ────────────────────────────────────────────────────────────
# Free tier: 30 RPM / 14400 RPD — extremely fast LPU inference
# Get your key at https://console.groq.com/keys
# Models: llama-3.1-8b-instant (fastest), llama-3.3-70b-versatile, mixtral-8x7b-32768
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=512
GROQ_TEMPERATURE=0.7

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Free-tier credits on sign-up; claude-3-haiku is the cheapest model
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_MAX_TOKENS=512
ANTHROPIC_TEMPERATURE=0.7
